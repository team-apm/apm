{
  "name": "apm",
  "version": "3.9.1",
  "description": "A package manager for AviUtl",
  "repository": "https://github.com/team-apm/apm.git",
  "license": "MIT",
  "author": "ato lash <28973861+hal-shu-sato@users.noreply.github.com>",
  "main": ".webpack/main",
  "scripts": {
    "cm": "npx cz",
    "fix": "run-s fix:prettier fix:eslint",
    "fix:eslint": "eslint --fix .",
    "fix:prettier": "prettier --write .",
    "lint": "run-s lint:prettier lint:eslint",
    "lint:eslint": "eslint --fix-dry-run .",
    "lint:prettier": "prettier --check .",
    "lint:ts": "tsc --noEmit",
    "make": "yarn run notices && electron-forge make",
    "notices": "yarn licenses generate-disclaimer --frozen-lockfile --prod --ignore-platform --ignore-engines --ignore-optional > ThirdPartyNotices.txt",
    "package": "yarn run notices && electron-forge package",
    "prepare": "husky",
    "publish": "yarn run notices && electron-forge publish",
    "release": "release-it",
    "release:major": "release-it major",
    "release:minor": "release-it minor",
    "release:patch": "release-it patch",
    "start": "cross-env NODE_ENV=development electron-forge start"
  },
  "lint-staged": {
    "*.js": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{ts,tsx,json,yml,md,html,css,scss}": "prettier --write"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "dependencies": {
    "7zip-bin": "^5.2.0",
    "@tanstack/react-query": "^5.101.1",
    "@trpc/client": "^10.45.4",
    "@trpc/react-query": "^10.45.4",
    "@trpc/server": "^10.45.4",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "clipboard": "^2.0.11",
    "compare-versions": "^6.1.1",
    "dot-prop": "^9.0.0",
    "electron-debug": "^4.1.0",
    "electron-dl": "^4.0.0",
    "electron-log": "^5.4.4",
    "electron-prompt": "^1.7.0",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^8.2.0",
    "electron-trpc": "^0.7.1",
    "electron-window-state": "^5.0.3",
    "fast-xml-parser": "^5.9.3",
    "fs-extra": "^11.3.5",
    "list.js": "^2.3.1",
    "matcher": "^5.0.0",
    "node-7z": "^3.0.0",
    "react": "^19.2.7",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.2.7",
    "source-map-support": "^0.5.21",
    "ssri": "^12.0.0",
    "update-electron-app": "^3.2.0",
    "win-7zip": "^0.1.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@electron-forge/cli": "6.4.1",
    "@electron-forge/maker-deb": "6.4.1",
    "@electron-forge/maker-rpm": "6.4.1",
    "@electron-forge/maker-squirrel": "6.4.1",
    "@electron-forge/maker-zip": "6.4.1",
    "@electron-forge/plugin-auto-unpack-natives": "6.4.1",
    "@electron-forge/plugin-webpack": "6.4.1",
    "@electron-forge/publisher-github": "6.4.1",
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/bootstrap": "^5.2.11",
    "@types/electron-prompt": "^1.6.5",
    "@types/electron-window-state": "^5.0.2",
    "@types/fs-extra": "^11.0.4",
    "@types/list.js": "^2.3.5",
    "@types/node-7z": "^2.1.11",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ssri": "^7.1.5",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vercel/webpack-asset-relocator-loader": "1.7.3",
    "apm-schema": "team-apm/apm-schema#v3.3.0",
    "commitizen": "^4.3.2",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "cz-conventional-changelog": "3.3.0",
    "cz-conventional-changelog-ja": "^0.0.2",
    "electron": "^34.5.8",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^50.8.0",
    "eslint-webpack-plugin": "^4.2.0",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "html-loader": "^5.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "mini-css-extract-plugin": "^2.10.2",
    "node-loader": "^2.1.0",
    "npm-run-all2": "^9.0.2",
    "prettier": "^3.8.5",
    "prettier-plugin-packagejson": "^2.5.22",
    "release-it": "^20.2.1",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  },
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": "24.x || 22.x"
  },
  "productName": "AviUtl Package Manager"
}

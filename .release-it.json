{
  "$schema": "https://unpkg.com/release-it/schema/release-it.json",
  "git": {
    "commit": true,
    "tag": true,
    "push": false,
    "commitMessage": "chore(release): ${version}"
  },
  "github": {
    "release": true,
    "draft": true,
    "releaseName": "AviUtl Package Manager v${version}"
  },
  "npm": {
    "publish": false
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "angular",
      "infile": "CHANGELOG.md"
    }
  }
}
